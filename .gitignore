# Keep the full source tree for Metin2 modules.
# Ignore only build outputs, IDE caches, and machine-specific files.

# Visual Studio user/cache files
.vs/
*.VC.db
*.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# Build outputs and debug symbols
[Dd]ebug/
[Rr]elease/
x64/
x86/
ipch/
obj/
bin/
build/
out/
OBJDIR/
.obj/
*.obj
*.o
*.lo
*.la
*.lai
*.pch
*.pdb
*.ipdb
*.iobj
*.idb
*.ilk
*.exp
*.lib.recipe
*.exe.recipe
*.dll
*.exe
*.app

# Static/import libs generated by builds
*.exp
*.ilk

# MSBuild / compiler logs and tracking
*.log
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
*.FileListAbsolute.txt

# CMake / generic native build systems
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
Makefile.Debug
Makefile.Release

# Temporary/editor files
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
Thumbs.db
Desktop.ini

# Python cache
__pycache__/
*.pyc
*.pyo

# Prebuilt third-party binaries that should stay local
ClientSource/extern/library/*.lib
ClientSource/extern/library/*.dll
ClientSource/extern/library/*.pdb
ClientSource/extern/library/*.rar
ClientSource/extern/library/*.bsc
ClientSource/binary/*.bsc
ServerSource/Extern/lib/*.a
ServerSource/Extern/cryptopp/*.o
ServerSource/Extern/cryptopp/*.exe
